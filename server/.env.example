PORT=5000
# Docker (docker compose в корне репозитория): postgres / postgres, БД burnout_db
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/burnout_db
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Отдельная панель /admin-portal (не путать с ролью admin в приложении)
ADMIN_PORTAL_LOGIN=123
ADMIN_PORTAL_PASSWORD=123

# Вход администратора через обычную страницу /login → /admin (PostgreSQL)
DEFAULT_ADMIN_EMAIL=admin@com
DEFAULT_ADMIN_PASSWORD=123
DEFAULT_ADMIN_NAME=Администратор
# SKIP_DEFAULT_ADMIN=1

# AI-помощник (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_MAX_INPUT_CHARS=2000
