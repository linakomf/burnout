# ChatGPT (OpenAI). Обязателен для полноценных ответов в дневнике и виджете «ИИ-помощник».
# Ключ: https://platform.openai.com/api-keys
REACT_APP_OPENAI_API_KEY=

# Необязательно: например gpt-4o-mini (по умолчанию), gpt-4o
# REACT_APP_OPENAI_MODEL=gpt-4o-mini

# Прод: если фронт и API на разных доменах — базовый URL API для /uploads и т.п.
# REACT_APP_API_ORIGIN=https://api.example.com

# Dev: если бэкенд не на 127.0.0.1:5000 — куда проксировать /api и /uploads (см. src/setupProxy.js)
# REACT_APP_DEV_PROXY_TARGET=http://127.0.0.1:5000

# Для кнопки «Написать специалисту» на главной: открывается почтовый клиент. Без этого — переход в дневник.
# REACT_APP_SUPPORT_EMAIL=support@example.com

# Если страница не открывается по localhost:3000, попробуйте в .env.development.local:
# HOST=127.0.0.1
# WDS_SOCKET_HOST=127.0.0.1
