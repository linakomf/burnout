{
  "name": "burnout-app",
  "version": "1.0.0",
  "description": "MindTrack - Психологическая поддержка для студентов и преподавателей",
  "scripts": {
    "install:all": "npm install --prefix server && npm install --prefix client",
    "setup": "node scripts/setup-dev.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "server": "node server/index.js",
    "client": "node scripts/start-client.cjs",
    "dev": "node node_modules/concurrently/dist/bin/concurrently.js \"node server/index.js\" \"node scripts/start-client.cjs\"",
    "start:all": "npm run db:up && npm run dev"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "serverless-http": "^3.2.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.14"
  }
}
